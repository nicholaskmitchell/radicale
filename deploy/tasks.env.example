# Copy to /etc/tasks/tasks.env  (mode 0600, owned by the service user).
# NEVER commit the real file — it holds secrets.

# --- Radicale (production, over localhost; never exposed directly) ---
RADICALE_URL=http://127.0.0.1:5232
RADICALE_USER=nicholaskmitchell
RADICALE_PASSWORD=REPLACE_with_radicale_password

# --- storage / static ---
TASKS_DB=/home/nicholaskmitchell/tasks/backend/tasks.db
TASKS_STATIC=/home/nicholaskmitchell/tasks/frontend/dist
TASKS_SYNC_INTERVAL=30

# --- app auth (REQUIRED; the public gate) ---
TASKS_AUTH_ENABLED=true
TASKS_AUTH_USER=nick
# Generate: cd ~/tasks/backend && .venv/bin/python -m tasksd hash-password
TASKS_AUTH_PASSWORD_HASH=REPLACE_scrypt_hash
# Generate: python3 -c "import secrets;print(secrets.token_hex(32))"
TASKS_SESSION_SECRET=REPLACE_64_hex_chars
TASKS_SESSION_TTL=604800
TASKS_COOKIE_SECURE=true

# --- storage-hook shared secret (must match /etc/tasks/hook-secret) ---
TASKS_HOOK_SECRET=REPLACE_hook_secret

# --- Cloudflare Access (OPTIONAL second layer; leave off for simple user/pass) ---
TASKS_ACCESS_REQUIRED=false
