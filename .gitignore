# ── Secrets / tokens — NEVER commit ──────────────────────────────────────────
# Real config lives in /etc/tasks/ (outside the repo). Only *.env.example ships.
*.env
!*.env.example
/deploy/tasks-cloudflared.env

# ── User content & derived cache (holds REAL synced calendar/task data) ──────
/backend/tasks.db
/backend/tasks.db-shm
/backend/tasks.db-wal
/backend/*.db
/backend/*.sqlite3

# ── Scratch Radicale runtime storage (test data) ─────────────────────────────
/scratch/data/

# ── Python ───────────────────────────────────────────────────────────────────
/backend/.venv/
__pycache__/
*.py[cod]
/backend/.pytest_cache/

# ── Node / frontend build artifacts (rebuilt by autopull) ────────────────────
/frontend/node_modules/
/frontend/dist/

# ── Logs & OS cruft ──────────────────────────────────────────────────────────
*.log
.DS_Store
